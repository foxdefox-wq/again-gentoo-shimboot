#!/bin/sh

# Release the ChromeOS frecon console so Xorg/LightDM can take over the display.
# shimboot binds /dev/console to frecon's PTY for early boot logs; X/LightDM need
# that bind mount gone before they try to claim a VT/DRM master.

umount -l /dev/console 2>/dev/null || true
pkill -9 frecon-lite 2>/dev/null || true
pkill -9 frecon 2>/dev/null || true

# The bootloader creates /dev/console as a regular file before bind-mounting
# frecon's PTY over it. After unmounting, restore the real console device node.
if [ ! -c /dev/console ]; then
    rm -f /dev/console 2>/dev/null || true
    mknod -m 600 /dev/console c 5 1 2>/dev/null || true
fi

sleep 1
exit 0
